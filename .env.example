# 币安自动交易脚本配置
BINANCE_BOT_ENABLED=true

# true=仅模拟，不下真实单；false=真实下单
BINANCE_BOT_DRY_RUN=true

# true=Spot Testnet；false=主网
BINANCE_BOT_TESTNET=false

# 真实下单时必填（Binance Spot）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 链上执行（BSC / OKX swap）
BSC_RPC_HTTPS=
BINANCE_BOT_WALLET_ADDRESS=
BINANCE_BOT_WALLET_PRIVATE_KEY=
# 可选：若不想分别提供 address/private_key，可改为提供一个本地 JSON 文件路径
BINANCE_BOT_WALLET_JSON=

# 交易参数
BINANCE_BOT_QUOTE_ASSET=USDT
BINANCE_BOT_MAX_USDT_PER_TRADE=0
